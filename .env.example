# Copy to .env and adjust for local development: `cp .env.example .env`
# NEVER commit a real .env. These values are safe local-only defaults.

# --- App ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Auth ---
# Comma-separated allowlist of accepted API keys. Generate strong, random
# keys for anything beyond local development.
API_KEYS=dev-key

# --- Rate limiting ---
RATE_LIMIT_PER_MINUTE=60

# --- Data layer ---
# When running the app inside docker-compose, hosts are "postgres"/"redis".
# When running the app on the host against compose services, use localhost.
DATABASE_URL=postgresql+psycopg://trust:trust@localhost:5432/trust
REDIS_URL=redis://localhost:6379/0

# --- Proof issuance (stub) ---
PROOF_VALID_FOR_HOURS=24

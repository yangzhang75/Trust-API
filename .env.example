# Copy to .env and adjust for local development: `cp .env.example .env`
# NEVER commit a real .env. These values are safe local-only defaults.

# --- App ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Auth ---
# Comma-separated allowlist of accepted API keys. Generate strong, random
# keys for anything beyond local development.
API_KEYS=dev-key
# Admin keys for the internal monitoring dashboard (Week 8). A dashboard key
# OR any API_KEYS entry grants dashboard access; blank = dashboard closed.
DASHBOARD_API_KEYS=

# --- Rate limiting ---
RATE_LIMIT_PER_MINUTE=60

# --- Data layer ---
# When running the app inside docker-compose, hosts are "postgres"/"redis".
# When running the app on the host against compose services, use localhost.
DATABASE_URL=postgresql+psycopg://trust:trust@localhost:5432/trust
REDIS_URL=redis://localhost:6379/0

# --- Proof issuance (Week 6: real Ed25519 signing) ---
# Base64-encoded 32-byte Ed25519 private seed. LEAVE BLANK in version control.
# Blank = the app generates an EPHEMERAL dev key at startup and logs a loud
# WARNING (proofs won't verify across restarts). Generate a dev key with:
#   python -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())"
PROOF_SIGNING_KEY=
# Proof lifetime in hours before expires_at.
PROOF_TTL_HOURS=24

# --- Ingestion (Week 2) ---
# Web3 data provider key (Etherscan V2). LEAVE BLANK in version control.
# Blank = live ingestion disabled (API still runs; worker/seed only
# register wallets). Get a free key at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=
ETHERSCAN_BASE_URL=https://api.etherscan.io/v2/api
INGESTION_TIMEOUT_SECONDS=10
INGESTION_MAX_ATTEMPTS=4
INGESTION_BACKOFF_SECONDS=0.5
INGESTION_MAX_TRANSACTIONS=1000
INGESTION_CACHE_TTL_SECONDS=21600

# --- Background worker ---
WORKER_INTERVAL_SECONDS=3600

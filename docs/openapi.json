{
  "components": {
    "schemas": {
      "Chain": {
        "description": "Supported EVM chains (Etherscan V2 via chainid). Non-EVM chains later.",
        "enum": [
          "ethereum",
          "arbitrum"
        ],
        "title": "Chain",
        "type": "string"
      },
      "ErrorResponse": {
        "description": "Uniform error envelope for documented 4xx responses.",
        "properties": {
          "detail": {
            "title": "Detail",
            "type": "string"
          }
        },
        "required": [
          "detail"
        ],
        "title": "ErrorResponse",
        "type": "object"
      },
      "HumanLikelihood": {
        "description": "Qualitative likelihood that the wallet is operated by a real human.",
        "enum": [
          "high",
          "medium",
          "low"
        ],
        "title": "HumanLikelihood",
        "type": "string"
      },
      "Proof": {
        "description": "A time-bounded, Ed25519-signed attestation of an assessment.\n\n``issued_at`` / ``expires_at`` are the EXACT ISO-8601 strings that were\nsigned (verbatim, not re-serialized), so a verifier can reconstruct the\nbyte-identical canonical payload. See docs/proof.md.",
        "properties": {
          "expires_at": {
            "title": "Expires At",
            "type": "string"
          },
          "issued_at": {
            "title": "Issued At",
            "type": "string"
          },
          "key_id": {
            "title": "Key Id",
            "type": "string"
          },
          "nonce": {
            "title": "Nonce",
            "type": "string"
          },
          "scorer_version": {
            "title": "Scorer Version",
            "type": "string"
          },
          "signature": {
            "title": "Signature",
            "type": "string"
          },
          "valid_for_hours": {
            "minimum": 1.0,
            "title": "Valid For Hours",
            "type": "integer"
          }
        },
        "required": [
          "issued_at",
          "expires_at",
          "valid_for_hours",
          "signature",
          "key_id",
          "nonce",
          "scorer_version"
        ],
        "title": "Proof",
        "type": "object"
      },
      "ProofVerifyRequest": {
        "description": "Request body for POST /proof/verify.\n\nDeliberately the same shape as a VerifyResponse: a consumer submits back\nexactly what /verify returned and we recheck it. Every signed field is\nrequired to reconstruct the canonical payload the signature covers.",
        "properties": {
          "chains": {
            "items": {
              "$ref": "#/components/schemas/Chain"
            },
            "title": "Chains",
            "type": "array"
          },
          "confidence_score": {
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Confidence Score",
            "type": "number"
          },
          "human_likelihood": {
            "$ref": "#/components/schemas/HumanLikelihood"
          },
          "proof": {
            "$ref": "#/components/schemas/Proof"
          },
          "risk_flags": {
            "items": {
              "$ref": "#/components/schemas/RiskFlag"
            },
            "title": "Risk Flags",
            "type": "array"
          },
          "trust_tier": {
            "$ref": "#/components/schemas/TrustTier"
          },
          "wallet": {
            "title": "Wallet",
            "type": "string"
          }
        },
        "required": [
          "wallet",
          "human_likelihood",
          "trust_tier",
          "confidence_score",
          "risk_flags",
          "chains",
          "proof"
        ],
        "title": "ProofVerifyRequest",
        "type": "object"
      },
      "ProofVerifyResponse": {
        "description": "200 response body for POST /proof/verify.",
        "properties": {
          "key_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Key Id"
          },
          "reason": {
            "title": "Reason",
            "type": "string"
          },
          "valid": {
            "title": "Valid",
            "type": "boolean"
          }
        },
        "required": [
          "valid",
          "reason"
        ],
        "title": "ProofVerifyResponse",
        "type": "object"
      },
      "RiskFlag": {
        "description": "Risk signals attached to an assessment (Week 4: emitted by real rules).",
        "enum": [
          "new_wallet",
          "low_activity",
          "low_counterparty_diversity",
          "bot_burst",
          "dormant",
          "sybil_suspected",
          "sybil_cluster"
        ],
        "title": "RiskFlag",
        "type": "string"
      },
      "TrustTier": {
        "description": "Coarse reputation tier assigned to a wallet.",
        "enum": [
          "bronze",
          "silver",
          "gold"
        ],
        "title": "TrustTier",
        "type": "string"
      },
      "VerifyRequest": {
        "additionalProperties": false,
        "description": "Request body for POST /verify.",
        "properties": {
          "chains": {
            "items": {
              "$ref": "#/components/schemas/Chain"
            },
            "minItems": 1,
            "title": "Chains",
            "type": "array"
          },
          "wallet": {
            "examples": [
              "0x52908400098527886E0F7030069857D2E4169EE7"
            ],
            "title": "Wallet",
            "type": "string"
          }
        },
        "required": [
          "wallet"
        ],
        "title": "VerifyRequest",
        "type": "object"
      },
      "VerifyResponse": {
        "description": "200 response body for POST /verify.",
        "properties": {
          "chains": {
            "items": {
              "$ref": "#/components/schemas/Chain"
            },
            "title": "Chains",
            "type": "array"
          },
          "confidence_score": {
            "maximum": 1.0,
            "minimum": 0.0,
            "title": "Confidence Score",
            "type": "number"
          },
          "human_likelihood": {
            "$ref": "#/components/schemas/HumanLikelihood"
          },
          "proof": {
            "$ref": "#/components/schemas/Proof"
          },
          "risk_flags": {
            "items": {
              "$ref": "#/components/schemas/RiskFlag"
            },
            "title": "Risk Flags",
            "type": "array"
          },
          "trust_tier": {
            "$ref": "#/components/schemas/TrustTier"
          },
          "wallet": {
            "title": "Wallet",
            "type": "string"
          }
        },
        "required": [
          "wallet",
          "human_likelihood",
          "trust_tier",
          "confidence_score",
          "risk_flags",
          "chains",
          "proof"
        ],
        "title": "VerifyResponse",
        "type": "object"
      }
    },
    "securitySchemes": {
      "APIKeyHeader": {
        "in": "header",
        "name": "X-API-Key",
        "type": "apiKey"
      }
    }
  },
  "info": {
    "description": "B2B Reputation-as-a-Service API. Week 1 returns deterministic stub data behind clean typed interfaces.",
    "title": "Proof-of-Human Trust API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/health": {
      "get": {
        "description": "Return service liveness status.",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Health Health Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Liveness probe",
        "tags": [
          "meta"
        ]
      }
    },
    "/metrics": {
      "get": {
        "description": "Expose in-process scoring counters in Prometheus text format.",
        "operationId": "metrics_metrics_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Scoring metrics (Prometheus text)",
        "tags": [
          "meta"
        ]
      }
    },
    "/proof/public-key": {
      "get": {
        "description": "Public key consumers use to verify proofs locally (no callback).",
        "operationId": "public_key_proof_public_key_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Public Key Proof Public Key Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Fetch the proof verification key",
        "tags": [
          "proof"
        ]
      }
    },
    "/proof/verify": {
      "post": {
        "description": "Recheck a submitted proof: reconstruct the canonical payload, verify the\nsignature/expiry with our key, and consult the DB for revocation.\n\nThis is a convenience endpoint; the same check runs offline with only the\npublic key (see docs/proof.md). Revocation is only consulted when a DB is\navailable.",
        "operationId": "verify_proof_proof_verify_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProofVerifyRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProofVerifyResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Missing or invalid API key"
          },
          "422": {
            "description": "Malformed request body"
          },
          "429": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Rate limit exceeded"
          }
        },
        "security": [
          {
            "APIKeyHeader": []
          }
        ],
        "summary": "Verify a previously issued proof",
        "tags": [
          "proof"
        ]
      }
    },
    "/verify": {
      "post": {
        "description": "Resolve features, score them, and return a signed proof.",
        "operationId": "verify_verify_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerifyRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VerifyResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Invalid wallet address"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Missing or invalid API key"
          },
          "422": {
            "description": "Malformed request body"
          },
          "429": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Rate limit exceeded"
          }
        },
        "security": [
          {
            "APIKeyHeader": []
          }
        ],
        "summary": "Assess the human-likelihood and trust tier of a wallet",
        "tags": [
          "verify"
        ]
      }
    }
  }
}
